# ══════════════════════════════════════════════════════════════════════════════
# .env — Secrets partagés entre toutes les instances
# Les paramètres par stratégie sont dans configs/rsi.env et configs/ensemble.env
#
# Lancement :
#   $env:STRATEGY_CONFIG = "configs\rsi.env"      ; cargo run --release
#   $env:STRATEGY_CONFIG = "configs\ensemble.env" ; cargo run --release
# ══════════════════════════════════════════════════════════════════════════════

# Mode d'exécution : dry-run | market | limit
# ⚠️  À définir dans chaque configs/*.env (pas ici)
# EXECUTION_MODE=dry-run

# Clé privée EVM (hex, avec ou sans "0x"). Requise pour mode market.
POLYMARKET_PRIVATE_KEY=

# Adresse funder Polymarket (proxy/safe) si différente de l'EOA signataire.
# POLYMARKET_FUNDER=

# Signature type Polymarket: 0=EOA, 1=POLY_PROXY, 2=GNOSIS_SAFE.
# POLYMARKET_SIGNATURE_TYPE=1

# Polymarket CLOB API
POLYMARKET_API_URL=https://clob.polymarket.com
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=

# Binance WebSocket (URL uniquement — SYMBOL/INTERVAL dans configs/*.env)
BINANCE_WS_URL=wss://stream.binance.com:9443/ws
