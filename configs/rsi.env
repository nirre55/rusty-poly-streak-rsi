# ── Stratégie RSI ────────────────────────────────────────────────────────────
STRATEGY=three_candle_rsi7_reversal
LOGS_DIR=logs/rsi
# dry-run | market | limit
EXECUTION_MODE=market

# Marché
SYMBOL=btcusdt
INTERVAL=5m
POLYMARKET_SLUG_PREFIX=btc-updown-5m

# Seuils RSI
RSI_OVERSOLD=35.0
RSI_OVERBOUGHT=65.0

# Montant par trade
TRADE_AMOUNT_PCT=1
# MARTINGALE_MULTIPLIER=1.5
# MARTINGALE_MAX_AMOUNT=50.0

# Filtres temporels
EXCLUDED_HOURS=00h-09h
# EXCLUDED_DAYS=sat,sun
