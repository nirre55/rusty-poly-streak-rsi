# Strategie BTC 5m combined - 23 micro-strategies
STRATEGY=btc_5m_rules_23_min_votes_1
LOGS_DIR=logs/btc_23_ensemble

# dry-run | market | limit
EXECUTION_MODE=limit

# Marche
SYMBOL=btcusdt
INTERVAL=5m
POLYMARKET_SLUG_PREFIX=btc-updown-5m

# Le rapport officiel de cette strategie utilise min_votes=1.
ENSEMBLE_MIN_VOTES=1

# Montant par trade
TRADE_AMOUNT_PCT=1

# Optionnel
# LIMIT_PRICE_OFFSET=0.01
# MARTINGALE_MULTIPLIER=1.5
# MARTINGALE_MAX_AMOUNT=50.0
