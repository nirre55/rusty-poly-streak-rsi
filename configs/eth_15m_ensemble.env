# ── Stratégie ETH 15m Ensemble 24 micro-règles ───────────────────────────────
STRATEGY=eth_15m_rules_24_min_votes_1
LOGS_DIR=logs/eth_15m_ensemble
# dry-run | market | limit
EXECUTION_MODE=limit

# Marché
SYMBOL=ethusdt
INTERVAL=15m
# ⚠️  Vérifier le préfixe exact sur Polymarket avant de lancer en mode market
POLYMARKET_SLUG_PREFIX=eth-updown-15m

# Votes minimum pour émettre un signal (1=max couverture, 3+=plus sélectif)
ENSEMBLE_MIN_VOTES=1

# Montant par trade
TRADE_AMOUNT_PCT=1
# MARTINGALE_MULTIPLIER=1.5
# MARTINGALE_MAX_AMOUNT=50.0

# Pas de filtre horaire pour cette stratégie
# EXCLUDED_HOURS=
# EXCLUDED_DAYS=sat,sun
