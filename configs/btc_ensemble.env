# ── Stratégie BTC Ensemble 90 micro-règles ───────────────────────────────────
STRATEGY=btc_5m_rules_90_min_votes_1
LOGS_DIR=logs/btc_ensemble

# Marché
SYMBOL=btcusdt
INTERVAL=5m
POLYMARKET_SLUG_PREFIX=btc-updown-5m

# Votes minimum pour émettre un signal (1=max couverture, 3+=plus sélectif)
ENSEMBLE_MIN_VOTES=1

# Montant par trade
TRADE_AMOUNT_PCT=1
# MARTINGALE_MULTIPLIER=1.5
# MARTINGALE_MAX_AMOUNT=50.0

# Pas de filtre horaire pour cette stratégie
# EXCLUDED_HOURS=
# EXCLUDED_DAYS=sat,sun
